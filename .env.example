# Telegram bot token from BotFather
TELEGRAM_BOT_TOKEN=123456789:YOUR_BOT_TOKEN_HERE

# Same Supabase details you use in the Streamlit Dashboard
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_KEY=YOUR_SUPABASE_ANON_OR_SERVICE_KEY

# Optional but recommended: use the same value in Vercel and local set_webhook.py
WEBHOOK_SECRET=make-a-long-random-secret-here

# Optional: restrict bot to selected group/private chat IDs, comma separated
# ALLOWED_CHAT_IDS=-1001234567890,123456789

# Optional: default top command size
DEFAULT_TOP_LIMIT=10
